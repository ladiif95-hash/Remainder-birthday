{
  "buildCommand": "cd nodemailer-auth/server && npm install && cd ../client && npm install && npm run build",
  "outputDirectory": "nodemailer-auth/client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
